{
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  "python.analysis.autoImportCompletions": true,
  "python.analysis.indexing": true,
  "python.analysis.packageIndexDepths": [
    { "name": "core", "depth": 4, "includeAllSymbols": true }
  ],

  // --- Réduction des suggestions IA intrusives ---
  // Coupe la complétion fantôme (texte gris) de Copilot et consorts
  "editor.inlineSuggest.enabled": false,
  // Désactive Copilot partout (réactive par langage au besoin)
  "github.copilot.enable": {
    "*": false
  },
  // Pas de popup de complétion pendant la frappe
  "editor.quickSuggestions": {
    "other": false,
    "comments": false,
    "strings": false
  },
  "editor.suggestOnTriggerCharacters": false,
  "editor.parameterHints.enabled": false
}